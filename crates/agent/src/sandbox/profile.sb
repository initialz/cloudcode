;; cloudcode workspace sandbox profile (macOS Seatbelt / SBPL).
;;
;; Strategy
;; --------
;; - default deny;
;; - read access is broad (so node, git, brew binaries, mise / asdf,
;;   etc. find the lib / config / dyld cache they expect to be there);
;; - explicit *deny* on directories that hold secrets (~/.ssh, ~/.aws,
;;   ~/.gnupg, Keychains, …) — overrides the broad read allow above
;;   because SBPL is last-rule-wins;
;; - write access is restricted to the active workspace, ~/.claude,
;;   a small whitelist of cache dirs, and the usual scratch dirs;
;; - even where writes are otherwise allowed, persistence vectors a
;;   compromised / hallucinating AI run might hit on its way past you
;;   (shell init files, LaunchAgents, .git/hooks) are denied;
;; - network is left fully open (claude needs Anthropic API, GitHub,
;;   package registries — an IP-level allowlist isn't workable against
;;   global CDNs);
;; - signals to own children only — can't poke same-uid host processes.
;;
;; Parameters supplied via sandbox_init_with_parameters:
;;   WORKSPACE  — abs path of the current workspace dir (rw allowed)
;;   HOME_DIR   — abs path of the user's home dir
;;
;; Notes
;; -----
;; The shell-init / git-hooks / secrets hardening pattern is a well-
;; known Unix isolation idiom (it shows up in macOS man pages, Chromium
;; sandbox docs, and many seatbelt profiles in the wild). The
;; implementation here is original — see Acknowledgements in the
;; project README.

(version 1)
(deny default)

;; ---------------------------------------------------------------------
;; process / sandbox visibility
;; ---------------------------------------------------------------------
(allow process-fork)
(allow process-exec)
;; Only see processes inside this same sandbox. Can't `ps` into host
;; processes (whose cmdlines / env may leak tokens or absolute paths).
(allow process-info* (target same-sandbox))
;; Signals: own children only.
(allow signal (target self))
(allow signal (target children))

;; ---------------------------------------------------------------------
;; read access
;; ---------------------------------------------------------------------
(allow file-read*)

;; ---------------------------------------------------------------------
;; secrets — deny both read and write, overriding the broad read above
;; ---------------------------------------------------------------------
;; Note ~/Library/Keychains is NOT in this list: claude stores its OAuth
;; token there ("Claude Code-credentials" in login.keychain-db) and
;; Security.framework needs to read/mmap the keychain file as part of
;; looking it up. Keychain access is already gated per-entry by macOS's
;; own keychain ACL (code-signed identity check) — denying the file
;; here would just break login without adding meaningful protection
;; against the entries another tool can already reach.
(deny file-read* file-write*
    (subpath (string-append (param "HOME_DIR") "/.ssh"))
    (subpath (string-append (param "HOME_DIR") "/.gnupg"))
    (subpath (string-append (param "HOME_DIR") "/.aws"))
    (subpath (string-append (param "HOME_DIR") "/.config/gcloud"))
    (subpath (string-append (param "HOME_DIR") "/Library/Cookies"))
    (subpath (string-append (param "HOME_DIR") "/Library/Application Support/com.apple.TCC")))

;; ---------------------------------------------------------------------
;; user / workspace isolation — two layers
;; ---------------------------------------------------------------------
;;
;; Layer 1: cross-user. /Users/<somebody-else> is denied content reads,
;; only the running user's own HOME_DIR survives. On a shared macOS
;; box this stops a session from peeking into other accounts' homes.
;; /Users/Shared (the public drop dir) is also denied — claude has no
;; reason to read it.
;;
;; Layer 2: cross-workspace within own home. The cloudcode WORKSPACE_ROOT
;; subtree is denied content reads except for the current session's own
;; WORKSPACE — so sibling workspaces and workspaces under other
;; cloudcode accounts stay invisible.
;;
;; Both denials only touch file-read-data + file-read-xattr.
;; file-read-metadata is left allowed by the broad (allow file-read*)
;; above so `stat` / path traversal still works through these dirs —
;; without that, `tmux`, `chdir`, and any tool walking parents would
;; fail.
;; ---------------------------------------------------------------------
(deny file-read-data file-read-xattr
    (require-all
        (subpath "/Users")
        (require-not (subpath (param "HOME_DIR")))))

(deny file-read-data file-read-xattr
    (require-all
        (subpath (param "WORKSPACE_ROOT"))
        (require-not (subpath (param "WORKSPACE")))))

;; ---------------------------------------------------------------------
;; write access — the active workspace
;; ---------------------------------------------------------------------
(allow file-write*
    (subpath (param "WORKSPACE")))

;; ---------------------------------------------------------------------
;; write access — claude state and the caches tooling needs
;; ---------------------------------------------------------------------
(allow file-write*
    (subpath (string-append (param "HOME_DIR") "/.claude"))
    (subpath (string-append (param "HOME_DIR") "/.cache"))
    (subpath (string-append (param "HOME_DIR") "/.npm"))
    (subpath (string-append (param "HOME_DIR") "/.cargo/registry"))
    (subpath (string-append (param "HOME_DIR") "/.config"))
    (subpath (string-append (param "HOME_DIR") "/.local"))
    (subpath (string-append (param "HOME_DIR") "/Library/Caches"))
    (subpath (string-append (param "HOME_DIR") "/Library/Application Support")))

;; ~/.claude.json* — claude stores its global config in a sibling file
;; of ~/.claude/, not under it. The .lock and .tmp.<pid>.<rand> variants
;; are atomic-write helpers.
(allow file-read* file-write*
    (regex (string-append "^" (param "HOME_DIR") "/\\.claude\\.json")))

;; ---------------------------------------------------------------------
;; write access — scratch and the controlling TTY
;; ---------------------------------------------------------------------
(allow file-write*
    (subpath "/private/tmp")
    (subpath "/private/var/tmp")
    (subpath "/private/var/folders")
    (literal "/dev/null")
    (literal "/dev/dtracehelper")
    (literal "/dev/tty")
    (literal "/dev/ptmx")
    (regex #"^/dev/ttys[0-9]+$")
    (regex #"^/dev/pty[a-z0-9]+$"))

;; PTY allocation + dtrace probes + tty winsize ioctls all need
;; file-ioctl on these nodes, which is a separate verb from file-write*.
(allow file-ioctl
    (literal "/dev/dtracehelper")
    (literal "/dev/tty")
    (literal "/dev/ptmx")
    (regex #"^/dev/ttys[0-9]+$")
    (regex #"^/dev/pty[a-z0-9]+$"))

;; Allocating a new pty pair (grantpt / ptsname / unlockpt) is a
;; distinct SBPL verb on macOS, independent of file-* on /dev/ptmx.
;; tmux needs this every time it opens a new window.
(allow pseudo-tty)

;; ---------------------------------------------------------------------
;; persistence defense — even within otherwise-writable paths, the
;; following are off-limits because they're how a bad / careless run
;; would survive the session:
;;
;;   shell init      — `~/.bashrc`, `~/.zshrc`, etc.
;;   launch agents   — `~/Library/LaunchAgents` (plist persistence)
;;   git hooks       — `.git/hooks/pre-commit`, `post-receive`, …
;; ---------------------------------------------------------------------
(deny file-write*
    (literal (string-append (param "HOME_DIR") "/.bashrc"))
    (literal (string-append (param "HOME_DIR") "/.bash_profile"))
    (literal (string-append (param "HOME_DIR") "/.bash_login"))
    (literal (string-append (param "HOME_DIR") "/.bash_logout"))
    (literal (string-append (param "HOME_DIR") "/.zshrc"))
    (literal (string-append (param "HOME_DIR") "/.zprofile"))
    (literal (string-append (param "HOME_DIR") "/.zlogin"))
    (literal (string-append (param "HOME_DIR") "/.zlogout"))
    (literal (string-append (param "HOME_DIR") "/.zshenv"))
    (literal (string-append (param "HOME_DIR") "/.profile"))
    (literal (string-append (param "HOME_DIR") "/.cshrc"))
    (literal (string-append (param "HOME_DIR") "/.tcshrc"))
    (subpath (string-append (param "HOME_DIR") "/.config/fish"))
    (subpath (string-append (param "HOME_DIR") "/Library/LaunchAgents"))
    (subpath (string-append (param "HOME_DIR") "/Library/LaunchDaemons")))

(deny file-write*
    (regex #".*/\.git/hooks/.*"))

;; ---------------------------------------------------------------------
;; network — fully open
;; ---------------------------------------------------------------------
(allow network*)
(allow system-socket)

;; ---------------------------------------------------------------------
;; hardware — block camera + microphone. Screen capture isn't listed
;; because it routes through TCC, and a sandboxed process has no TCC
;; grant. These are also implicitly denied by `(deny default)` above —
;; they're written out explicitly to document intent and to keep this
;; bar from being lowered by accident in some future edit.
;; ---------------------------------------------------------------------
(deny device-camera)
(deny device-microphone)

;; ---------------------------------------------------------------------
;; macOS plumbing — coarse for v1. Required for launchd-spawned helpers,
;; dyld shared cache, font / audio subsystems, etc. Narrowing these
;; safely requires per-OS-version testing; will iterate once we have
;; telemetry on what claude's toolchain actually touches.
;; ---------------------------------------------------------------------
(allow mach-lookup)
(allow mach-priv-host-port)
(allow ipc-posix-shm)
(allow ipc-posix-sem)
(allow ipc-sysv-shm)
(allow iokit-open)
(allow sysctl-read)
